# Copie este arquivo para .env.local e preencha.
# Gere segredos aleatórios com: openssl rand -base64 32

# --- Banco de dados ---
# Dev (SQLite local): DATABASE_URL=file:./sulco.db
# Prod (Turso/libsql): DATABASE_URL=libsql://<seu-db>.turso.io  +  DATABASE_AUTH_TOKEN=<token-turso>
DATABASE_URL=file:./sulco.db
# DATABASE_AUTH_TOKEN=

# --- Autenticação (Clerk) ---
# Crie uma aplicação em https://dashboard.clerk.com e copie as chaves abaixo.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Webhook: registre o endpoint https://<dominio>/api/webhooks/clerk no dashboard da Clerk
# e copie o signing secret para a variável abaixo.
CLERK_WEBHOOK_SECRET=

# --- Segredo de cifragem do Personal Access Token do Discogs (FR-004) ---
# Gere com: openssl rand -base64 32
MASTER_ENCRYPTION_KEY=

# --- Autenticação do cron Vercel (FR-032) ---
# Gere com: openssl rand -base64 32
# Em prod, configure a mesma string nas Env Vars do projeto Vercel.
CRON_SECRET=

# --- Owner do Sulco (FR-012, 002-multi-conta) ---
# Email do dono do piloto. Primeiro user autenticado com email verified
# igual a este valor recebe `users.is_owner=true` automaticamente via
# webhook Clerk. Demais verificações de admin usam o bit, não o email.
# Deve ser exatamente o mesmo email configurado no Clerk Allowlist
# como primeira entrada.
OWNER_EMAIL=
